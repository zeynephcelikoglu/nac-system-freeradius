server default {

listen {
    type = auth
    ipaddr = *
    port = 1812
    limit {
          max_connections = 16
          lifetime = 0
          idle_timeout = 900
    }
}

listen {
    ipaddr = *
    port = 1813
    type = acct
}

authorize {
    filter_username
    preprocess
    chap
    mschap
    digest
    suffix
    eap {
        ok = return
    }
    files
    -sql
    -ldap
    expiration
    logintime
    
    # API Sorgusu için REST modülü
    rest
    
    # Eğer API 'ok' dönerse girişe izin ver (Auth-Type := Accept)
    if (ok) {
        update control {
            &Auth-Type := Accept
        }
    }
    
    pap
}

authenticate {
    Auth-Type PAP {
        pap
    }
    Auth-Type CHAP {
        chap
    }
    Auth-Type MS-CHAP {
        mschap
    }
    mschap
    digest
    eap
}

preacct {
    preprocess
    acct_unique
    suffix
    files
}

accounting {
    detail
    sql
    exec
    attr_filter.accounting_response
    
    # Accounting verilerini de API'ye gönder (Accounting %15 kısmı için)
    rest
}

session {
}

post-auth {
    # VLAN ve Yetkilendirme için API'ye tekrar sor
    rest

    if (session-state:User-Name && reply:User-Name && request:User-Name && (reply:User-Name == request:User-Name)) {
        update reply {
            &User-Name !* ANY
        }
    }
    update {
        &reply: += &session-state:
    }

    sql
    exec
    remove_reply_message_if_eap

    Post-Auth-Type REJECT {
        -sql
        attr_filter.access_reject
        eap
        remove_reply_message_if_eap
    }

    if (EAP-Key-Name && &reply:EAP-Session-Id) {
        update reply {
            &EAP-Key-Name := &reply:EAP-Session-Id
        }
    }
}

pre-proxy {
}

post-proxy {
    exec
    remove_reply_message_if_eap
}

}